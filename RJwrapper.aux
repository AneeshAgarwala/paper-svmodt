\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Comparison of mean prediction accuracy (mean \(\pm \) standard deviation) across maximum feature selection strategies for SVMODT, with results benchmarked against the Python STree implementation All SVMODT models were trained using maximum depth parameter (\(d_{\max }=15\)), mutual-information feature ranking, and adaptive feature selection. The constant strategy uses a fixed number of candidate features at each node; the decrease strategy progressively reduces the number of available features with tree depth (\(\alpha \) = 0.5); the random strategy samples the candidate feature proportion uniformly from the interval \(l_{\min }=0.5\) to \(l_{\max }=0.8\) at each split. Bold values indicate the highest prediction accuracy for each dataset.}}{9}{table.caption.5}\protected@file@percent }
\newlabel{tab:svmodt-max-features-accuracy-score-table-latex}{{2}{9}{Comparison of mean prediction accuracy (mean \(\pm \) standard deviation) across maximum feature selection strategies for SVMODT, with results benchmarked against the Python STree implementation All SVMODT models were trained using maximum depth parameter (\(d_{\max }=15\)), mutual-information feature ranking, and adaptive feature selection. The constant strategy uses a fixed number of candidate features at each node; the decrease strategy progressively reduces the number of available features with tree depth (\(\alpha \) = 0.5); the random strategy samples the candidate feature proportion uniformly from the interval \(l_{\min }=0.5\) to \(l_{\max }=0.8\) at each split. Bold values indicate the highest prediction accuracy for each dataset}{table.caption.5}{}}
\@writefile{toc}{\contentsline {paragraph}{Feature Selection Method}{9}{table.caption.5}\protected@file@percent }
\newlabel{feature-selection-method}{{24}{9}{Feature Selection Method}{table.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Comparison of random, mutual, and correlated feature selection methods using SVMODT on the Palmer Penguins dataset.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:palmer-penguins-feature-selection-split-latex}{{3}{10}{Comparison of random, mutual, and correlated feature selection methods using SVMODT on the Palmer Penguins dataset}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {paragraph}{Feature Penalty Mechanism}{10}{table.caption.7}\protected@file@percent }
\newlabel{feature-penalty-mechanism}{{24}{10}{Feature Penalty Mechanism}{table.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Comparison of mean prediction accuracy across feature selection strategies for SVMODT, benchmarked against the Python STree implementation. All SVMODT models were trained using \(d_{\max }=15\). The random strategy selects candidate predictors using random subset sampling \(n_{\text  {subsets}} = 10\); the mutual information strategy ranks predictors according to their dependency with the response variable; the correlation strategy ranks predictors using absolute correlation with the response. STree does not employ an explicit pre-split feature ranking mechanism, instead optimising the node classifier directly on the available predictors. Bold values indicate the highest prediction accuracy for each dataset.}}{11}{table.caption.7}\protected@file@percent }
\newlabel{tab:svmodt-feature-selection-table-latex}{{3}{11}{Comparison of mean prediction accuracy across feature selection strategies for SVMODT, benchmarked against the Python STree implementation. All SVMODT models were trained using \(d_{\max }=15\). The random strategy selects candidate predictors using random subset sampling \(n_{\text {subsets}} = 10\); the mutual information strategy ranks predictors according to their dependency with the response variable; the correlation strategy ranks predictors using absolute correlation with the response. STree does not employ an explicit pre-split feature ranking mechanism, instead optimising the node classifier directly on the available predictors. Bold values indicate the highest prediction accuracy for each dataset}{table.caption.7}{}}
\newlabel{fig:wine-feature-penalty-1}{{4a}{11}{Feature Penalty Mechanism}{subfigure.4.1}{}}
\newlabel{fig:wine-feature-penalty-2}{{4b}{11}{Feature Penalty Mechanism}{subfigure.4.2}{}}
\newlabel{fig:wine-feature-penalty-3}{{4c}{11}{Feature Penalty Mechanism}{subfigure.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Comparison of Low, Medium and High penalty on repeated features by SVMODT on Wine dataset.}}{11}{figure.caption.8}\protected@file@percent }
\newlabel{fig:wine-feature-penalty}{{4}{11}{Comparison of Low, Medium and High penalty on repeated features by SVMODT on Wine dataset}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {No Penalty}}}{11}{subfigure.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {Low (0.2)}}}{11}{subfigure.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(c)}{\ignorespaces {Medium (0.5)}}}{11}{subfigure.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Comparison of mean prediction accuracy (mean \(\pm \) standard deviation) across feature penalisation strategies for SVMODT. All models were trained using \(d_{\max }=15\), mutual-information feature ranking, and adaptive maximum feature selection. No penalisation corresponds to reuse of previously selected features being unrestricted. Low, medium, and high penalisation correspond to feature penalty weights of \(\lambda \) = 0.2, \(\lambda \) = 0.5, and \(\lambda \) = 0.8, respectively. Bold values indicate the highest accuracy for each dataset.}}{12}{table.caption.9}\protected@file@percent }
\newlabel{tab:svmodt-features-penalty-score-table-latex}{{4}{12}{Comparison of mean prediction accuracy (mean \(\pm \) standard deviation) across feature penalisation strategies for SVMODT. All models were trained using \(d_{\max }=15\), mutual-information feature ranking, and adaptive maximum feature selection. No penalisation corresponds to reuse of previously selected features being unrestricted. Low, medium, and high penalisation correspond to feature penalty weights of \(\lambda \) = 0.2, \(\lambda \) = 0.5, and \(\lambda \) = 0.8, respectively. Bold values indicate the highest accuracy for each dataset}{table.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Comparison of tree structure and predictive accuracy across minimum sample thresholds on the WDBC dataset. All SVMODT models were trained using the random maximum feature strategy and mutual information feature ranking. Higher minimum sample thresholds restrict further node splitting and therefore produce shallower tree structures.}}{12}{table.caption.10}\protected@file@percent }
\newlabel{tab:min-split-table-latex}{{5}{12}{Comparison of tree structure and predictive accuracy across minimum sample thresholds on the WDBC dataset. All SVMODT models were trained using the random maximum feature strategy and mutual information feature ranking. Higher minimum sample thresholds restrict further node splitting and therefore produce shallower tree structures}{table.caption.10}{}}
